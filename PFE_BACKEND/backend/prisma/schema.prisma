generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  fullName     String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  scans        Scan[]

  @@map("users")
}

model Vulnerability {
  id          Int      @id @default(autoincrement())
  cveId       String?  @unique
  title       String
  description String
  severity    String
  cvssScore   Float?
  source      String   @default("discovered")

  scans       ScanResult[]
}

model Scan {
  id        Int      @id @default(autoincrement())
  targetUrl String
  createdAt DateTime @default(now())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  metadata  Json     @default("{}")
  results   ScanResult[]

  @@index([userId])
  @@index([createdAt])
}

model ScanResult {
  id              Int  @id @default(autoincrement())
  scanId          Int
  vulnerabilityId Int
  evidence        String

  scan            Scan          @relation(fields: [scanId], references: [id])
  vulnerability   Vulnerability @relation(fields: [vulnerabilityId], references: [id])

  @@index([scanId])
  @@index([vulnerabilityId])
}
